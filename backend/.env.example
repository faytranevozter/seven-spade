PORT=5050
GO_ENV=development

# logger
LOG_TO_STDOUT=true
LOG_MAX_SIZE=50

# db connection (PostgreSQL)
DB_URL=postgres://postgres:postgres@localhost:5432/seven_spade?sslmode=disable

# redis cache
USE_REDIS=true
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=60s
REDIS_KEY_PREFIX="sevenspade:"

# jwt
JWT_MEMBER_SECRET_KEY=change-me-to-a-random-secret
JWT_MEMBER_TTL=1440 # in minutes (24 hours)

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth - Telegram
TELEGRAM_BOT_TOKEN=

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5050
WS_ORIGIN=http://localhost:5173

# S3 (optional, for avatars)
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=bucket-name
S3_PUBLIC_URL=

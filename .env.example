# =============================================================================
# Seven Spade — Docker Compose Environment
# Copy this file to .env and fill in your values before running docker compose.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=seven_spade

# --- Backend App ---
PORT=5050
GO_ENV=production
LOG_TO_STDOUT=true
LOG_MAX_SIZE=50

# --- Redis ---
USE_REDIS=true
REDIS_TTL=60s
REDIS_KEY_PREFIX="sevenspade:"

# --- JWT ---
JWT_MEMBER_SECRET_KEY=change-me-to-a-long-random-secret
JWT_MEMBER_TTL=1440 # in minutes (24 hours)

# --- OAuth - Google (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth - GitHub (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- OAuth - Telegram (optional) ---
TELEGRAM_BOT_TOKEN=

# --- URLs (update for your deployment) ---
# For local docker compose, use http://localhost (frontend on port 80)
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:5050
WS_ORIGIN=http://localhost

# --- S3 (optional, for avatars) ---
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=
